{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gitify",
  "version": "0.1.0",
  "identifier": "net.tail80680d.gitify",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Gitify",
        "width": 1100,
        "height": 720,
        "minWidth": 380,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
