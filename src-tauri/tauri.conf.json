{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gitify",
  "version": "0.1.0",
  "identifier": "net.tail80680d.gitify",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Gitify",
        "width": 1100,
        "height": 720,
        "minWidth": 380,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "files": {
          "/usr/bin/gitify-tui": "gitify-tui"
        }
      }
    }
  }
}
